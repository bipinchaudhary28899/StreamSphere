# ─────────────────────────────────────────────────────────────────────────────
# StreamSphere Backend — Environment Variables
#
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random string:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-jwt-secret-here

# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (or local: mongodb://localhost:27017/streamsphere)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL — used for feed caching, view dedup, and API stats counters
# Local:  redis://localhost:6379
# Upstash: rediss://<user>:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── AWS ───────────────────────────────────────────────────────────────────────
# IAM user must have: s3:PutObject, s3:GetObject, s3:DeleteObject,
#                     cloudwatch:GetMetricStatistics (for the dev dashboard)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# ── CloudFront ────────────────────────────────────────────────────────────────
CLOUDFRONT_URL=https://your-cloudfront-domain.cloudfront.net
# Distribution ID — used by the dev dashboard to query CloudWatch metrics
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXX

# ── Hugging Face ──────────────────────────────────────────────────────────────
HUGGING_FACE_API_KEY=hf_your_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:4200,https://your-frontend.vercel.app